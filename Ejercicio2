package resolNizS;

public class Ejercicio2 {
    public static void ejecutar(String[] args) {
        if (args.length == 0) {
            System.out.println("Debe ingresar un número");
            return;
        }

        int n = Integer.parseInt(args[0]);
        System.out.println(n % 2 == 0 ? "Es par" : "Es impar");
    }
}
